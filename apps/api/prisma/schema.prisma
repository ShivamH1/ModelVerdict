generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Session {
  id         String   @id @default(uuid())
  messagesA  Json
  messagesB  Json
  modelIdA   String
  modelIdB   String
  isRevealed Boolean  @default(false)
  votedFor   String?
  createdAt  DateTime @default(now())
  eloDelta   Json?
}

model InferenceLog {
  id                 String   @id @default(uuid())
  sessionId          String
  modelId            String
  modelName          String
  prompt             String
  response           String
  latencyMs          Int
  inputTokens        Int
  outputTokens       Int
  estimatedCostUsd   Float
  status             String
  guardrailTriggered Boolean
  guardrailReason    String?
  timestamp          DateTime @default(now())
  retryAttempt       Int?
  retryOf            String?
  retryProvider      String?
  retryReason        String?
}

model EvalRun {
  id          String   @id @default(uuid())
  status      String
  startedAt   DateTime @default(now())
  completedAt DateTime?
}

model EvalResult {
  id               String   @id @default(uuid())
  runId            String
  promptId         String
  category         String
  prompt           String
  expectedBehavior String?
  modelIdA         String
  modelIdB         String
  responseA        String
  responseB        String
  scoresA          Json
  scoresB          Json
  latencyMsA       Int
  latencyMsB       Int
}
